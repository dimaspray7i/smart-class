# ═══════════════════════════════════════════════════════════
# 🎓 RPL SMART ECOSYSTEM - FRONTEND ENVIRONMENT
# ═══════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════
# 🔗 API CONFIGURATION
# ═══════════════════════════════════════════════════════════

# Backend Laravel API URL
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# API Timeout (milliseconds)
VITE_API_TIMEOUT=20000

# ═══════════════════════════════════════════════════════════
# 🎨 APP CONFIGURATION
# ═══════════════════════════════════════════════════════════

# Application Name
VITE_APP_NAME="RPL Smart"

# Application Version
VITE_APP_VERSION=1.0.0

# Default Theme (light/dark)
VITE_DEFAULT_THEME=light

# ═══════════════════════════════════════════════════════════
# 🔐 AUTHENTICATION CONFIGURATION
# ═══════════════════════════════════════════════════════════

# Token Storage Key
VITE_TOKEN_STORAGE_KEY=rpl_token

# User Storage Key
VITE_USER_STORAGE_KEY=rpl_user

# Token Expiry (minutes) - should match backend
VITE_TOKEN_EXPIRY=43200

# ═══════════════════════════════════════════════════════════
# 🚩 FEATURE FLAGS
# ═══════════════════════════════════════════════════════════

# Enable/Disable Features
VITE_ENABLE_GALLERY=true
VITE_ENABLE_SIMULATOR=true
VITE_ENABLE_PROJECTS=true
VITE_ENABLE_SKILLS=true
VITE_ENABLE_ATTENDANCE=true

# ═══════════════════════════════════════════════════════════
# 📸 ATTENDANCE CONFIGURATION
# ═══════════════════════════════════════════════════════════

# Max photo size (MB)
VITE_MAX_PHOTO_SIZE=5

# Allowed photo extensions
VITE_PHOTO_EXTENSIONS=jpg,jpeg,png,webp

# Attendance radius info (for display)
VITE_ATTENDANCE_RADIUS=100

# ═══════════════════════════════════════════════════════════
# 🌐 CORS & SECURITY
# ═══════════════════════════════════════════════════════════

# Enable/Disable debug mode
VITE_DEBUG=true

# Enable/Disable error logging
VITE_ENABLE_ERROR_LOGGING=true

# ═══════════════════════════════════════════════════════════
# 📊 ANALYTICS & MONITORING
# ═══════════════════════════════════════════════════════════

# Enable analytics (if using Google Analytics, etc)
VITE_ENABLE_ANALYTICS=false

# Analytics ID (if applicable)
VITE_ANALYTICS_ID=

# ═══════════════════════════════════════════════════════════
# 🔧 DEVELOPMENT SETTINGS
# ═══════════════════════════════════════════════════════════

# Enable React DevTools
VITE_ENABLE_REACT_DEVTOOLS=true

# Enable Query DevTools (React Query)
VITE_ENABLE_QUERY_DEVTOOLS=true