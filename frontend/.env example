# API Configuration
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
VITE_API_TIMEOUT=15000

# App Configuration
VITE_APP_NAME="RPL Smart"
VITE_APP_VERSION=1.0.0
VITE_DEFAULT_THEME=light

# Authentication
VITE_TOKEN_STORAGE_KEY=rpl_token
VITE_USER_STORAGE_KEY=rpl_user
VITE_TOKEN_EXPIRY=43200

# Feature Flags
VITE_ENABLE_GALLERY=true
VITE_ENABLE_SIMULATOR=true
VITE_ENABLE_PROJECTS=true
VITE_ENABLE_SKILLS=true
VITE_ENABLE_ATTENDANCE=true

# Attendance
VITE_MAX_PHOTO_SIZE=5
VITE_PHOTO_EXTENSIONS=jpg,jpeg,png,webp
VITE_ATTENDANCE_RADIUS=100

# Debug
VITE_DEBUG=true
VITE_ENABLE_ERROR_LOGGING=true

# Analytics
VITE_ENABLE_ANALYTICS=false
VITE_ANALYTICS_ID=

# Development
VITE_ENABLE_REACT_DEVTOOLS=true
VITE_ENABLE_QUERY_DEVTOOLS=true